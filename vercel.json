{
  "version": 2,
  "ignoreCommand": "git log -1 --pretty=%s | grep -qE '^chore: sync' && exit 0 || exit 1",
  "git": {
    "deploymentEnabled": {
      "data": false
    }
  },
  "rewrites": [
    { "source": "/historico_completo.json", "destination": "https://raw.githubusercontent.com/ssg-create/ssg-dashboard/data/historico_completo.json" },
    { "source": "/tickets_ativos.json",     "destination": "https://raw.githubusercontent.com/ssg-create/ssg-dashboard/data/tickets_ativos.json" },
    { "source": "/utilizacao.json",         "destination": "https://raw.githubusercontent.com/ssg-create/ssg-dashboard/data/utilizacao.json" },
    { "source": "/gwms-insights.json",      "destination": "https://raw.githubusercontent.com/ssg-create/ssg-dashboard/data/gwms-insights.json" },
    { "source": "/aios-insights.json",      "destination": "https://raw.githubusercontent.com/ssg-create/ssg-dashboard/data/aios-insights.json" },
    { "source": "/silenciosos.json",        "destination": "https://raw.githubusercontent.com/ssg-create/ssg-dashboard/data/silenciosos.json" },
    { "source": "/triagem.json",            "destination": "https://raw.githubusercontent.com/ssg-create/ssg-dashboard/data/triagem.json" },
    { "source": "/reaberturas.json",        "destination": "https://raw.githubusercontent.com/ssg-create/ssg-dashboard/data/reaberturas.json" }
  ]
}
